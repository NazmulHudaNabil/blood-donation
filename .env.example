# Copy this to .env and fill in real values. Never commit the real .env file.

# postgresql+psycopg://<user>:<password>@<host>:5432/<database>
# Under docker-compose this is overridden automatically to point at the `db`
# service — see docker-compose.yml — so this value only matters when running
# the app directly on your host (uv run fastapi dev ...).
DATABASE_URL=postgresql+psycopg://username:password@localhost:5432/blood_donation

# Generate a real one with: openssl rand -hex 32
# Must be at least 32 characters — shorter values are rejected outright when
# ENVIRONMENT=production, and just logged as a warning otherwise.
SECRET_KEY=changeme-generate-a-real-32-plus-character-secret

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# development | production — production enforces the SECRET_KEY length check.
ENVIRONMENT=development

# Verbose SQL logging (every statement + bound params) — leave off outside
# local debugging, it can leak sensitive values (e.g. password hashes) into logs.
DB_ECHO=false

# Comma-separated list of browser origins allowed to call this API.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Only used by docker-compose.yml to configure the `db` service and to build
# the DATABASE_URL it injects into `api`. Ignored when running without Docker.
POSTGRES_USER=blood_donation
POSTGRES_PASSWORD=changeme
POSTGRES_DB=blood_donation
